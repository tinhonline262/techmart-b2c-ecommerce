{
  "info": {
    "_postman_id": "techmart-product-api-2026",
    "name": "TechMart Product Service - Public API",
    "description": "Collection for testing TechMart Product Service public endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Get All Products (Paginated & Filtered)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8081/api/v1/public/products?page=0&size=10&categoryIds=1,2&brandIds=1&minPrice=100&maxPrice=1000&inStock=true&sortBy=price&sortDirection=asc",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "public", "products"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" },
            { "key": "categoryIds", "value": "1,2" },
            { "key": "brandIds", "value": "1" },
            { "key": "minPrice", "value": "100" },
            { "key": "maxPrice", "value": "1000" },
            { "key": "inStock", "value": "true" },
            { "key": "sortBy", "value": "price" },
            { "key": "sortDirection", "value": "asc" }
          ]
        },
        "description": "Get all published products with multi-criteria filtering and pagination"
      },
      "response": []
    },
    {
      "name": "2. Get Featured Products",
