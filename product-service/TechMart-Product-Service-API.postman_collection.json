          "protocol": "http",
          "host": ["localhost"],
          "port": "8081",
          "path": ["api", "v1", "public", "products", "featured"],
          "query": [{ "key": "limit", "value": "10" }]
        },
        "description": "Get top featured products for homepage or promotional displays"
      },
      "response": []
    },
