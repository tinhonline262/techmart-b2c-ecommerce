                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dell XPS 13\",\n  \"description\": \"Ultra-portable premium laptop\",\n  \"price\": 1299.99,\n  \"stockQuantity\": 50,\n  \"categoryIds\": [1],\n  \"brandId\": 1,\n  \"templateId\": 1,\n  \"sku\": \"DELL-XPS-13-001\",\n  \"attributes\": [\n    {\n      \"attributeId\": 1,\n      \"value\": \"Intel Core i7-12700H\"\n    },\n    {\n      \"attributeId\": 2,\n      \"value\": \"16GB DDR5\"\n    },\n    {\n      \"attributeId\": 3,\n      \"value\": \"NVIDIA RTX 3050 Ti\"\n    },\n    {\n      \"attributeId\": 4,\n      \"value\": \"512GB NVMe SSD\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8081/api/v1/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "v1", "products"]
            },
            "description": "Create product using template with attribute values. Expected: 201 Created with templateId and attributes in response"
